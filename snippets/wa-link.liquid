{%- comment -%}
  Devuelve la URL de WhatsApp con el número y mensaje configurados en el tema.
  Uso: <a href="{% render 'wa-link' %}">  (opcional: message: 'texto personalizado')
{%- endcomment -%}
{%- assign num = settings.whatsapp_number | remove: ' ' | remove: '+' | remove: '-' | remove: '(' | remove: ')' -%}
{%- assign msg = message | default: settings.whatsapp_message -%}
https://wa.me/{{ num }}?text={{ msg | url_encode }}
