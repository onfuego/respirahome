  },
  {
    "name": "Contacto y WhatsApp",
    "settings": [
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "Número de WhatsApp",
        "info": "Formato internacional sin +, espacios ni guiones. Chile: 56 + 9 + 8 dígitos. Ej: 56912345678",
        "default": "56900000000"
      },
      {
        "type": "textarea",
        "id": "whatsapp_message",
        "label": "Mensaje pre-cargado de WhatsApp",
        "default": "¡Hola RespiraHome! Quiero agendar una sesión de kinesiología a domicilio."
      },
      { "type": "text", "id": "phone_display", "label": "Teléfono visible (opcional)", "default": "+56 9 0000 0000" },
      { "type": "text", "id": "email", "label": "Email de contacto", "default": "contacto@respirahome.cl" }
    ]
  },
  {
    "name": "Redes sociales",
    "settings": [
      { "type": "url", "id": "instagram_url", "label": "Instagram" },
      { "type": "url", "id": "facebook_url", "label": "Facebook" }
    ]
  },
  {
    "name": "Horario y recargos",
    "settings": [
      { "type": "text", "id": "hours_text", "label": "Días de atención", "default": "Lunes a Domingo" },
      { "type": "text", "id": "hours_open", "label": "Hora de apertura", "default": "08:00" },
      { "type": "text", "id": "hours_close", "label": "Hora de cierre", "default": "18:00" },
      {
        "type": "number",
        "id": "after_hours_surcharge",
        "label": "Recargo fuera de horario (CLP)",
        "info": "Se suma en el cotizador al elegir 'fuera de horario'. Por definir.",
        "default": 8000
      }
    ]
  },
  {
    "name": "Marca",
    "settings": [
      { "type": "image_picker", "id": "logo", "label": "Logo (opcional, usa el SVG por defecto si se deja vacío)" },
      { "type": "image_picker", "id": "favicon", "label": "Favicon (opcional)" }
    ]
  }
